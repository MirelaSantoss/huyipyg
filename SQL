-- criação do banco de dados
CREATE DATABASE Escola3FN
GO
USE Escola3FN -- vai ativar o banco de dados

--criar tabela

CREATE TABLE Departamento(
    id_depto INT PRIMARY KEY,
    nome_depto VARCHAR (50) NOT NULL
); --não precisa de ponto e virgula no MS SQLServer

select * from Departamento

CREATE TABLE Professor(
    id_prof INT PRIMARY KEY,
    nome_prof VARCHAR(60) not null,
    id_depto INT FOREIGN KEY  REFERENCES Departamento(id_depto) --chave estrangeira
);

CREATE TABLE Disciplina(
    cod_disc CHAR(5),
    nome_disc VARCHAR(60) not null,
    PRIMARY KEY(cod_disc)
);

CREATE TABLE Turma(
   cod_turma CHAR(3),
   cod_disc CHAR(5),
   id_prof INT,
   sala VARCHAR(10),
   --dEFINIÇOES DE CHAVES
   PRIMARY KEY (cod_turma),
   FOREIGN KEY (cod_disc) REFERENCES Disciplina(cod_disc),
   FOREIGN KEY (id_prof) REFERENCES Professor (id_prof)
);


CREATE TABLE Aluno (
    id_matricula INT PRIMARY KEY,
    nome VARCHAR(60) NOT NULL
);

CREATE TABLE Telefone (
    id_telefone INT IDENTITY(1,1) PRIMARY KEY,
    id_matricula INT FOREIGN KEY REFERENCES Aluno(id_matricula),
    numero VARCHAR(15) NOT NULL
);

CREATE TABLE Matricula (
    id_matricula INT FOREIGN KEY REFERENCES Aluno(id_matricula),
    cod_turma CHAR(3) FOREIGN KEY REFERENCES Turma(cod_turma),
    PRIMARY KEY (id_matricula, cod_turma)
);
            

